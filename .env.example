# AWS
AWS_REGION=us-east-1
AWS_PROFILE=default

# Vault
VAULT_ADDR=https://vault.example.com
VAULT_TOKEN=

# Terraform
TF_VAR_vpc_id=vpc-xxxxxxxxx
TF_VAR_subnet_ids=["subnet-aaa","subnet-bbb","subnet-ccc"]
TF_VAR_domain_name=vault.example.com
TF_VAR_environment=prod

# Vault Secrets Engine – AWS
TF_VAR_vault_aws_access_key=
TF_VAR_vault_aws_secret_key=

# Vault Secrets Engine – Database
TF_VAR_db_host=postgres.example.com
TF_VAR_db_port=5432
TF_VAR_db_name=appdb
TF_VAR_db_admin_username=
TF_VAR_db_admin_password=

# Kubernetes Integration
TF_VAR_enable_k8s_integration=false
TF_VAR_kubernetes_host=https://k8s.example.com
TF_VAR_k8s_cluster_name=production

# Backup
S3_BUCKET=xops-vault-backups
